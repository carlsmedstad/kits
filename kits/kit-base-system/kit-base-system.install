# shellcheck shell=bash

post_install() {
  /usr/lib/kit-base-system/render-crypttab-initramfs

  echo "To enable systemd-oomd, run:"
  echo ""
  echo "  sudo systemctl daemon-reload"
  echo "  sudo systemctl enable --now systemd-oomd.service"
}

post_upgrade() {
  /usr/lib/kit-base-system/render-crypttab-initramfs
}
